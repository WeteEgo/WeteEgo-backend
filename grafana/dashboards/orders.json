{
  "title": "WeteEgo Orders",
  "panels": [
    {
      "id": 1,
      "title": "Order volume by status",
      "type": "stat",
      "targets": [
        {
          "expr": "sum by (status) (increase(weteego_orders_total[24h]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Orders by provider",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (provider) (weteego_orders_total)",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Order duration (p50/p95/p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(weteego_order_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(weteego_order_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(weteego_order_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    }
  ],
  "schemaVersion": 38
}
