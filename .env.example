# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/weteego

# Server
PORT=3001

# Chain: 84532 = Base Sepolia, 8453 = Base mainnet
CHAIN_ID=84532

# WeteEgoRouter deployed address
ROUTER_ADDRESS=0x

# RPC endpoint
RPC_URL=https://sepolia.base.org

# Paycrest integration
PAYCREST_API_URL=https://api.paycrest.io
PAYCREST_API_KEY=
PAYCREST_WEBHOOK_SECRET=

# CoinGecko (optional fallback for rates)
COINGECKO_API_KEY=

# CORS: set to your frontend origin in production (never use * in production)
CORS_ORIGIN=http://localhost:3000

# Redis (optional; for rate limiting and pub/sub)
REDIS_URL=redis://localhost:6379

# Admin API key for /admin/* routes
ADMIN_KEY=
