datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id            String      @id @default(cuid())
  settlementRef String      @unique // bytes32 hex — links on-chain tx to this record
  walletAddress String
  tokenAddress  String
  amount        String      // USDC amount in wei (BigInt stored as string)
  fiatCurrency  String
  fiatAmount    Float
  rate          Float
  status        OrderStatus @default(PENDING)
  txHash        String?     // populated after SwapForwarded / OrderCreated event indexed
  paycrestRef   String?     // Paycrest internal order ref received via webhook
  provider      String?    // "paycrest" | "bread" | "own"
  expiresAt     DateTime    @default(now()) // order valid until createdAt + 10 min
  bankAccount   String?    // JSON: { accountNumber, bankCode, accountName }
  version       Int         @default(0) // optimistic lock — increment on every status update
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([walletAddress])
  @@index([status])
}

enum OrderStatus {
  PENDING   // order created, awaiting on-chain tx
  FORWARDED // SwapForwarded event seen on-chain (Router path)
  ESCROWED  // Gateway contract has locked USDC (OrderCreated event)
  EXPIRED   // order created but no on-chain tx within 10 min
  SETTLED   // Paycrest webhook confirmed fiat payout
  REFUNDED  // Gateway refund after timeout
  FAILED    // payout failed
}
